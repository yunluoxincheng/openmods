#!/usr/bin/env node

import { spawnSync } from "child_process"
import { fileURLToPath } from "url"
import { dirname, join } from "path"
import { platform } from "os"
import { existsSync } from "fs"

const __filename = fileURLToPath(import.meta.url)
const __dirname = dirname(__filename)

function getBinaryPath() {
  const isWindows = platform() === "win32"
  const binaryName = isWindows ? "openmods.exe" : "openmods"
  
  const localBinary = join(__dirname, binaryName)
  if (existsSync(localBinary)) {
    return localBinary
  }
  
  const hiddenBinary = join(__dirname, ".openmods")
  if (existsSync(hiddenBinary)) {
    return hiddenBinary
  }
  
  return null
}

const binaryPath = getBinaryPath()

if (!binaryPath) {
  console.error("\n\x1b[31mError: OpenMods binary not found.\x1b[0m\n")
  console.error("This may happen if the installation was incomplete.")
  console.error("Try reinstalling: npm install -g openmods-ai\n")
  process.exit(1)
}

const result = spawnSync(binaryPath, process.argv.slice(2), {
  stdio: "inherit",
  cwd: process.cwd(),
})

if (result.error) {
  console.error(result.error.message)
  process.exit(1)
}

const code = typeof result.status === "number" ? result.status : 0
process.exit(code)